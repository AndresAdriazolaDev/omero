  "AutoRegisterTargets9B45660A": {
   "Type": "AWS::Lambda::Function",
   "Properties": {
    "Code": {
     "ZipFile": {
      "Fn::Join": [
       "",
       [
        "\nimport boto3, logging\nlogger = logging.getLogger()\nlogger.setLevel(logging.INFO)\n\ndef handler(event, context):\n    try:\n        elbv2 = boto3.client('elbv2')\n        detail = event['detail']\n        last_status = detail['lastStatus']\n        if 'omero-web' not in detail.get('group', ''):\n            return {'statusCode': 200}\n        for attachment in detail.get('attachments', []):\n            if attachment.get('type') == 'eni':\n                for d in attachment.get('details', []):\n                    if d.get('name') == 'privateIPv4Address':\n                        ip = d['value']\n                        az = detail.get('availabilityZone', '')\n                        tg_arn = '",
        {
         "Ref": "TgWebB0EE06C8"
        },
        "'\n                        if last_status == 'RUNNING':\n                            elbv2.register_targets(TargetGroupArn=tg_arn, Targets=[{'Id': ip, 'Port': 4080, 'AvailabilityZone': az}])\n                        elif last_status == 'STOPPED':\n                            elbv2.deregister_targets(TargetGroupArn=tg_arn, Targets=[{'Id': ip, 'Port': 4080, 'AvailabilityZone': az}])\n                        return {'statusCode': 200}\n    except Exception as e:\n        logger.error(str(e))\n        return {'statusCode': 500}\n"
       ]
      ]
     }
    },
    "FunctionName": "lambda-omero-register-targets-dev",
    "Handler": "index.handler",
    "Role": {
     "Fn::GetAtt": [
      "AutoRegisterTargetsServiceRoleDA8B1BAE",
      "Arn"
     ]
    },
    "Runtime": "python3.13",
    "Timeout": 30
   },
   "DependsOn": [
    "AutoRegisterTargetsServiceRoleDefaultPolicy4F95EAE1",
    "AutoRegisterTargetsServiceRoleDA8B1BAE"
   ],
